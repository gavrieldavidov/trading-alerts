# ===== הגדרות Telegram (אופציונלי) =====
# 1. פתח Telegram וחפש @BotFather
# 2. שלח /newbot ועקוב אחרי ההוראות
# 3. קבל את הטוקן ורשום אותו כאן
TELEGRAM_BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. שלח הודעה לבוט שלך, אחר כך פתח:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. מצא את "id" בתוך "chat" ורשום אותו כאן
TELEGRAM_CHAT_ID=123456789

# ===== ניהול סיכונים =====
# גודל חשבון בדולרים (לחישוב גודל פוזיציה)
ACCOUNT_SIZE=10000

# ===== הגדרות סריקה =====
# כמה שניות בין סריקות (מינימום 30)
SCAN_INTERVAL=60
